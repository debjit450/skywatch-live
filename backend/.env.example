# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
ALLOWED_HOSTS=api.example.com
CSRF_TRUSTED_ORIGINS=https://api.example.com,https://example.com
CORS_ALLOWED_ORIGINS=https://example.com
# Local development example:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# Database and Redis are required when DJANGO_DEBUG=False.
DATABASE_URL=postgres://skywatch:change-me@localhost:5432/skywatch
REDIS_URL=redis://localhost:6379/0
ALLOW_IN_MEMORY_CHANNEL_LAYER=False

# OpenSky Network credentials
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Optional security/logging overrides
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_PRELOAD=False
LOG_LEVEL=INFO
